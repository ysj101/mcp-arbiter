# --- Mode ---
# local | cloud
ARBITER_MODE=local

# --- Policies (local モード) ---
# proxy 起動時にこの JSON をロードして storage に seed する。未設定なら default-policies.json。
# 自前の憲法を試したいときは sample-policy.json をコピーして編集し、ここで指定する。
# ARBITER_POLICIES_FILE=packages/proxy/fixtures/default-policies.json

# --- Downstream MCP ツール ---
# proxy が ALLOW 時に中継する MCP サーバ。子プロセスとして spawn される (stdio)。
# 既定は dummy-email-mcp。別の MCP に差し替えたいときはここを変更する。
# ARBITER_DOWNSTREAM_COMMAND=node
# ARBITER_DOWNSTREAM_ARGS=packages/mcp-tool/dist/server.js

# --- Storage (local モード) ---
# 1 にすると local モードでも InMemory ではなく Cosmos Emulator (docker compose) を使う。
# proxy 再起動を跨いでも policy / verdict が残る。未設定なら InMemoryStorageAdapter（揮発）。
# ARBITER_USE_COSMOS=1

# --- Cosmos DB ---
# ARBITER_USE_COSMOS=1 または ARBITER_MODE=cloud で参照される。既定値は Cosmos Emulator のもの。
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DATABASE=arbiter

# --- SignalR ---
SIGNALR_CONNECTION_STRING=Endpoint=http://localhost:8888;Port=8888;AccessKey=ABCDEFG;Version=1.0;

# --- LLM backend (local モード) ---
# local モードの既定は claude-cli（Claude Code CLI を子プロセスで呼ぶ）。
# CLI が未インストール / 未認証の場合は mock にフォールバック。
ARBITER_LLM_BACKEND=claude-cli
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_MODEL=claude-sonnet-4-6
CLAUDE_CLI_TIMEOUT_MS=60000

# --- LLM (cloud モード: Azure Foundry Agent Service) ---
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- Auth ---
# local モード: 共有 Bearer token。cloud モードでは Entra ID に差し替える
ARBITER_SHARED_SECRET=dev-shared-secret-change-me
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# --- Dashboard ---
NEXT_PUBLIC_ARBITER_MODE=local

# Dashboard が Proxy の /verdicts と /events を読むための URL（local 専用）。
# Cloud モードでは Cosmos / Web PubSub に直接繋ぐ想定なので参照されない。
ARBITER_PROXY_URL=http://localhost:7071
