{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ARBITER_MODE": "local"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(colima status)",
      "Bash(colima start:*)",
      "Bash(docker info)",
      "Bash(func:*)",
      "Bash(gh:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(jq:*)"
    ],
    "ask": [
      "Bash(docker compose down:*)",
      "Bash(colima stop:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr merge:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push -f origin main:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/deny-env-commit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-reminder.sh"
          }
        ]
      }
    ]
  }
}
