{
  "name": "@arbiter/proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arbiter-proxy": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "dev": "ARBITER_POLICIES_FILE=${ARBITER_POLICIES_FILE:-fixtures/default-policies.json} ARBITER_DOWNSTREAM_COMMAND=${ARBITER_DOWNSTREAM_COMMAND:-node} ARBITER_DOWNSTREAM_ARGS=${ARBITER_DOWNSTREAM_ARGS:-../mcp-tool/dist/server.js} node --import tsx src/server.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@arbiter/core": "workspace:*",
    "@arbiter/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.8.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
