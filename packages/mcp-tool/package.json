    "dev": "node --import tsx src/server.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@arbiter/shared-types": "workspace:*",
    "@modelcontextprotocol/sdk": "1.0.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
