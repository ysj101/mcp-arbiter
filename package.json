{
  "name": "mcp-arbiter",
  "version": "0.0.0",
  "private": true,
  "description": "A Constitution Layer for Agentic Systems",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.0.0-rc.5",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.0-rc.5",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "docker compose down",
    "dev:status": "bash scripts/dev-status.sh",
    "harness:run": "node packages/harness/dist/cli.js --markdown harness/report.md --json harness/report.json",
    "e2e:local": "pnpm -r build && tsx scripts/e2e-local.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
